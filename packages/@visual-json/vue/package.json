{
  "name": "@visual-json/vue",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "Vue 3 components for visual-json — the visual JSON editor. Schema-aware, embeddable, extensible.",
  "keywords": [
    "json",
    "editor",
    "vue",
    "tree",
    "visual"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "prepack": "node ../../../scripts/resolve-workspace-deps.mjs",
    "postpack": "node ../../../scripts/restore-package-json.mjs",
    "check-types": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,vue}\""
  },
  "dependencies": {
    "@visual-json/core": "workspace:*"
  },
  "devDependencies": {
    "@internal/ui": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.10",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  }
}
