{
  "name": "@visual-json/react",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "description": "React components for visual-json — the visual JSON editor. Schema-aware, embeddable, extensible.",
  "keywords": [
    "json",
    "editor",
    "react",
    "tree",
    "visual"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "node ../../../scripts/resolve-workspace-deps.mjs",
    "postpack": "node ../../../scripts/restore-package-json.mjs",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@visual-json/core": "workspace:*"
  },
  "devDependencies": {
    "@internal/ui": "workspace:*",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
